# Example environment variables for local runs.
#
# Do NOT commit real credentials. Keep your actual values in a local `.env`.
#
# Option A (optional): single DATABASE_URL for a lower-friction local workflow.
# The Python entrypoints do not require this variable, but you may choose it as a
# single connection string for both Python and psql commands.
# DATABASE_URL=postgresql://USER:PASS@localhost:5432/DBNAME

# Option B: discrete connection fields (used if DATABASE_URL is not set)
DB_USER=your_user
DB_PASS=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db

# Optional
# Where the Olist CSVs live locally
DATA_DIR=./data

# Raw schema name in Postgres.
# IMPORTANT: SQL assets reference `Olist.olist_*` (unquoted), which resolves to `olist`.
RAW_SCHEMA=olist
